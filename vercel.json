{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://localhost:8080/api/$1" },
    { "source": "/myhk/(.*)", "destination": "https://myhkw.cn/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "build": {
    "command": "npm run build",
    "outputDirectory": "dist"
  }
}
